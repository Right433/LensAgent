BASE_URL = "https://yxai.anthropic.edu.pl"
MODEL    = "gemini-2.5-flash-preview-05-20"

PROMPT = """你是光学设计专家。基于 CDGM 玻璃库和近轴追迹模型，生成12条结构化镜头优化skill。


payload = json.dumps({
    "model": MODEL,
    "max_tokens": 4000,
    "messages": [{"role": "user", "content": PROMPT}]
}).encode()

req = urllib.request.Request(
    f"{BASE_URL}/v1/messages",
    data=payload,
    headers={
        "Content-Type": "application/json",
        "x-api-key": API_KEY,
        "anthropic-version": "2023-06-01"
    },
    method="POST"
)

print("调用 Gemini 生成 skill...")
try:
    with urllib.request.urlopen(req, timeout=60) as r:
        result = json.loads(r.read())
        skill_text = result["content"][0]["text"]
        print("生成成功！")
        print("-" * 60)
        print(skill_text)
        print("-" * 60)

        # 写入 lens_skills.py
        output = f'LENS_SKILLS = """\n{skill_text}\n"""\n'
        with open("/gz-data/lens_skills.py", "w", encoding="utf-8") as f:
            f.write(output)
        print("已保存到 /gz-data/lens_skills.py")

except urllib.error.HTTPError as e:
    body = e.read().decode()
    print(f"HTTP {e.code}: {body}")
    # 如果模型名不对，打印可用模型
    if e.code == 404 or "model" in body.lower():
        print("\n可能模型名有误，尝试列出可用模型...")
        req2 = urllib.request.Request(
            f"{BASE_URL}/v1/models",
            headers={"x-api-key": API_KEY, "anthropic-version": "2023-06-01"},
            method="GET"
        )
        try:
            with urllib.request.urlopen(req2, timeout=10) as r2:
                models = json.loads(r2.read())
                print(json.dumps(models, indent=2, ensure_ascii=False))
        except Exception as e2:
            print(f"列模型失败: {e2}")
except Exception as e:
    print(f"ERROR: {e}")
